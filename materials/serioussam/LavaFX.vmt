"LightmappedGeneric"
{
	$basetexture "serioussam/LavaFX"
	
	"%compilewater" 1

	// This is needed for physics, etc.
	"$surfaceprop" "water"
	
	// You must have this. . this is a material that is practically identical
	// to this one in most cases.  It must have $reflecttexture disabled, and
	// you can set for params uniquely for underLava.
	"$bottommaterial" "serioussam/LavaFX_beneath"

	// This is needed for the proxy below which animates the normal map, etc.
	"$bumpframe" "0"

	// Enable Lava volumetric fog.
	"$fogenable" 0

	// This is the color of the fog in the Lava when looking from above.
	// You'll have the same thing in the bottom material for when looking from 
	// below.
	"$fogcolor" "{250 0 5}"

	// This is the distance in inches from the eye which Lava fog starts.
	// This has to be 0.0 for edge fading to work properly.
	"$fogstart" 0.00

	// This is the distance in inches from the eye which Lava fog ends.
	"$fogend" 150.00

	"$abovewater" 1	

	"$texoffset" "[0 0]"

	// The Lava generally looks better if we scale it down a bit
	"$texscale" "0.5"
	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$basetexture"
			"animatedtextureframenumvar" "$frame"
			"animatedtextureframerate" 26
		}


		"TextureTransform"
		{
			"translateVar" "$texoffset"
			"scaleVar" "$texscale"
			"resultVar" "$basetexturetransform"
		}
	}
}
